COMPOSE_PROJECT_NAME=ech_nginx
TZ=America/New_York

NGINX_VERSION=1.29.4
OPENSSL_GIT_REF=replace-with-your-openssl-ech-git-ref
NGINX_SHA256=
APP_IMAGE=local/ech-nginx:nginx-1.29.4-openssl-ech

HOST_BIND_IP=0.0.0.0
HOST_PORT=9444

PROTECTED_NAME=protected.example.com
PUBLIC_NAME=public.example.com

INTERNAL_CONNECT_IP=127.0.0.1
INTERNAL_PORT=9444
INTERNAL_DNS_SERVER=127.0.0.1

PUBLIC_DNS_SERVER=1.1.1.1
EXTERNAL_PORT=443

CLOUDFLARE_ZONE_NAME=example.com
CLOUDFLARE_API_TOKEN_FILE=./secrets/cloudflare-api-token
ECH_CONFIG_FILE=./ech/protected.example.com.pem.ech
